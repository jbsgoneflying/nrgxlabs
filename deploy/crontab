# Raven-Tech scheduled jobs (all times UTC)
# Logs go to /var/log/cron.log inside the container

# Engine 3 (backend: engine5_lead_lag): refresh global lead-lag snapshot (feeds regime + sequencer)
0 9 * * 1-5  cd /app && python3 scripts/refresh_engine5_snapshot.py >> /var/log/cron.log 2>&1

# Engine 9 (calendar): refresh earnings calendar snapshot
10 9 * * 1-5 cd /app && python3 scripts/refresh_calendar_snapshot.py >> /var/log/cron.log 2>&1

# DMS: rebuild daily market state + morning brief
30 9 * * 1-5 cd /app && python3 scripts/refresh_daily_market_state.py >> /var/log/cron.log 2>&1

# Engine 6 (backend: engine7_pairs): nightly LLM theme review
45 9 * * 1-5 curl -sf -X POST http://localhost:8000/api/engine7-pairs/nightly-review >> /var/log/cron.log 2>&1

# Engine 17 (backend: ai_capex): AI Capex Reality Engine — full daily scan (Tier-1 ingest + LLM extract + Tier-2 web agent -> Redis). Run as a script (not HTTP) so the ~70-ticker LLM pass isn't bound by the request timeout.
0 8 * * 1-5 cd /app && python3 scripts/refresh_ai_capex.py >> /var/log/cron.log 2>&1

# Engine 12 (backend: engine12_vix_fade): VIX spike monitor (every 15 min during US market hours, 9am-9pm UTC)
*/15 9-21 * * 1-5 cd /app && python3 scripts/engine12_spike_monitor.py >> /var/log/cron.log 2>&1

# Sequencer breadth: earnings dispersion, red dog breadth, ichimoku breadth
0 21 * * 1-5 cd /app && python3 scripts/refresh_sequencer_state.py >> /var/log/cron.log 2>&1

# Weekly roadmap: Sunday evening (generates planning brief)
0 22 * * 0   cd /app && python3 scripts/refresh_daily_market_state.py --weekly >> /var/log/cron.log 2>&1

# Daily trade archive (weekdays after market close — shrinks data loss window to ~1 day)
0 22 * * 1-5 cd /app && python3 scripts/archive_trades.py >> /var/log/cron.log 2>&1

# Weekly trade review: Sunday evening (generates LLM trade learning review + trade archive backup)
30 22 * * 0  curl -sf -X POST http://localhost:8000/api/trade-review/weekly/generate >> /var/log/cron.log 2>&1
45 22 * * 0  cd /app && python3 scripts/archive_trades.py >> /var/log/cron.log 2>&1

